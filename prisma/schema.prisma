generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Gestor {
  id        String   @id @default(cuid())
  empresaId String?  @map("empresa_id")
  nome      String
  email     String   @unique
  senha     String
  telefone  String?
  cargo     String   @default("CEO")
  autorizado Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  empresa    Empresa? @relation(fields: [empresaId], references: [id])
  clientes   Cliente[]
  emissoes   Emissao[]
  transacoes Transacao[]
  contas     ContaPrograma[]
  leadsPrimeiroContato Lead[] @relation("LeadPrimeiroContato")
  callsCriadas CallVenda[] @relation("CallCriadaPor")
  callsParticipante CallParticipante[]
  produtosResponsavel ProdutoCliente[]
  notificacoes Notificacao[]
  movimentacoesMilhas MovimentacaoMilhas[]

  @@map("gestores")
}

model Empresa {
  id        String   @id @default(cuid())
  nome      String
  marca     String   @default("Atlas Beyond Destinations")
  createdAt DateTime @default(now()) @map("created_at")

  gestores Gestor[]
  leads    Lead[]
  metas    MetaMensal[]

  @@map("empresas")
}

model Programa {
  id        Int    @id @default(autoincrement())
  nome      String
  companhia String
  cor       String @default("#6366f1")

  contas   ContaPrograma[]
  emissoes Emissao[]

  @@map("programas")
}

model Cliente {
  id             String    @id @default(cuid())
  gestorId       String    @map("gestor_id")
  nome           String
  email          String?
  telefone       String?
  cpf            String?
  fotoUrl        String?   @map("foto_url")
  dataNascimento DateTime? @map("data_nascimento")
  observacoes    String?
  feeMensal      Decimal   @default(0) @map("fee_mensal") @db.Decimal(10, 2)
  feePorEmissao  Decimal   @default(0) @map("fee_por_emissao") @db.Decimal(10, 2)
  metaEconomia   Decimal   @default(0) @map("meta_economia") @db.Decimal(12, 2)
  produtoContratado String? @map("produto_contratado")
  acessoInicio   DateTime? @map("acesso_inicio")
  acessoFim      DateTime? @map("acesso_fim")
  ativo          Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")

  gestor     Gestor          @relation(fields: [gestorId], references: [id], onDelete: Cascade)
  contas     ContaPrograma[]
  emissoes   Emissao[]
  transacoes Transacao[]
  cartoes    CartaoCredito[]
  produtos   ProdutoCliente[]
  renovacoes Renovacao[]
  leads      Lead[]

  @@map("clientes")
}

model ContaPrograma {
  id                     String    @id @default(cuid())
  clienteId              String    @map("cliente_id")
  gestorId               String    @map("gestor_id")
  programaId             Int       @map("programa_id")
  numeroConta            String?   @map("numero_conta")
  saldoAtual             Int       @default(0) @map("saldo_atual")
  valorMilheiro          Decimal?  @map("valor_milheiro") @db.Decimal(10, 2)
  clubeMensalMilhas      Int?      @map("clube_mensal_milhas")
  custoMensal            Decimal?  @map("custo_mensal") @db.Decimal(10, 2)
  ultimaAtualizacaoSaldo DateTime? @map("ultima_atualizacao_saldo")
  ultimaVisualizacao     DateTime? @map("ultima_visualizacao")
  createdAt              DateTime  @default(now()) @map("created_at")

  cliente  Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  gestor   Gestor   @relation(fields: [gestorId], references: [id], onDelete: Cascade)
  programa Programa @relation(fields: [programaId], references: [id])
  movimentacoes MovimentacaoMilhas[]

  @@map("contas_programas")
}

model CartaoCredito {
  id               String   @id @default(cuid())
  clienteId        String   @map("cliente_id")
  nome             String
  pontosPorDolar   Decimal  @default(0) @map("pontos_por_dolar") @db.Decimal(10, 2)
  salasVipTotal    Int      @default(0) @map("salas_vip_total")
  salasVipUsadas   Int      @default(0) @map("salas_vip_usadas")
  createdAt        DateTime @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  movimentacoes MovimentacaoMilhas[]

  @@map("cartoes_credito")
}

model MovimentacaoMilhas {
  id              String   @id @default(cuid())
  contaProgramaId String   @map("conta_programa_id")
  gestorId        String   @map("gestor_id")
  cartaoId        String?  @map("cartao_id")
  tipo            String   @default("MANUAL")
  quantidade      Int
  custoTotal      Decimal  @default(0) @map("custo_total") @db.Decimal(10, 2)
  descricao       String?
  faturaValor     Decimal? @map("fatura_valor") @db.Decimal(10, 2)
  dolarCotacao    Decimal? @map("dolar_cotacao") @db.Decimal(10, 4)
  pontosPorDolar  Decimal? @map("pontos_por_dolar") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  contaPrograma ContaPrograma @relation(fields: [contaProgramaId], references: [id], onDelete: Cascade)
  gestor        Gestor        @relation(fields: [gestorId], references: [id], onDelete: Cascade)
  cartao        CartaoCredito? @relation(fields: [cartaoId], references: [id], onDelete: SetNull)

  @@map("movimentacoes_milhas")
}

model Lead {
  id                         String    @id @default(cuid())
  empresaId                  String?   @map("empresa_id")
  clienteId                  String?   @map("cliente_id")
  primeiroContatoGestorId    String?   @map("primeiro_contato_gestor_id")
  nome                       String
  whatsapp                   String
  email                      String
  origem                     String?
  indicadoPor                String?   @map("indicado_por")
  gastoMensal                String?   @map("gasto_mensal")
  statusCall                 String    @default("AGUARDANDO_ENTREVISTA") @map("status_call")
  statusFinal                String    @default("LEAD") @map("status_final")
  primeiroContatoRealizado   Boolean   @default(false) @map("primeiro_contato_realizado")
  followUpInicio             DateTime? @map("follow_up_inicio")
  callMarcadaPara            DateTime? @map("call_marcada_para")
  createdAt                  DateTime  @default(now()) @map("created_at")

  empresa Empresa? @relation(fields: [empresaId], references: [id])
  cliente Cliente? @relation(fields: [clienteId], references: [id])
  primeiroContatoGestor Gestor? @relation("LeadPrimeiroContato", fields: [primeiroContatoGestorId], references: [id])
  respostas LeadResposta[]
  calls CallVenda[]

  @@map("leads")
}

model LeadResposta {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  bloco     String
  pergunta  String
  resposta  String
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_respostas")
}

model QuestionarioEvento {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  eventType String   @map("event_type")
  stepIndex Int?     @map("step_index")
  stepLabel String?  @map("step_label")
  path      String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([eventType])
  @@index([createdAt])
  @@map("questionario_eventos")
}

model CallVenda {
  id            String   @id @default(cuid())
  leadId        String?  @map("lead_id")
  criadoPorId   String?  @map("criado_por_id")
  origemCliente String   @default("FUNIL") @map("origem_cliente")
  dataHora      DateTime? @map("data_hora")
  produto       String?
  valor         Decimal? @db.Decimal(10, 2)
  fechou        Boolean?
  observacoes   String?
  createdAt     DateTime @default(now()) @map("created_at")

  lead Lead? @relation(fields: [leadId], references: [id])
  criadoPor Gestor? @relation("CallCriadaPor", fields: [criadoPorId], references: [id])
  participantes CallParticipante[]

  @@map("calls_vendas")
}

model CallParticipante {
  id        String @id @default(cuid())
  callId    String @map("call_id")
  gestorId  String @map("gestor_id")

  call   CallVenda @relation(fields: [callId], references: [id], onDelete: Cascade)
  gestor Gestor    @relation(fields: [gestorId], references: [id], onDelete: Cascade)

  @@unique([callId, gestorId])
  @@map("call_participantes")
}

model Emissao {
  id               String   @id @default(cuid())
  gestorId         String   @map("gestor_id")
  clienteId        String   @map("cliente_id")
  programaId       Int?     @map("programa_id")
  origem           String
  destino          String
  dataVoo          DateTime @map("data_voo")
  passageiros      Int      @default(1)
  milhasUtilizadas Int      @default(0) @map("milhas_utilizadas")
  precoMercado     Decimal  @default(0) @map("preco_mercado") @db.Decimal(10, 2)
  taxasPagas       Decimal  @default(0) @map("taxas_pagas") @db.Decimal(10, 2)
  feeCobrado       Decimal  @default(0) @map("fee_cobrado") @db.Decimal(10, 2)
  classe           String   @default("Econômica")
  status           String   @default("confirmada")
  observacoes      String?
  createdAt        DateTime @default(now()) @map("created_at")

  gestor     Gestor      @relation(fields: [gestorId], references: [id], onDelete: Cascade)
  cliente    Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  programa   Programa?   @relation(fields: [programaId], references: [id])
  transacoes Transacao[]

  @@map("emissoes")
}

model ProdutoCliente {
  id               String   @id @default(cuid())
  clienteId        String   @map("cliente_id")
  responsavelId    String?  @map("responsavel_id")
  tipo             String
  nome             String?
  status           String   @default("EM_COTACAO")
  local            String?
  origem           String?
  destino          String?
  dataSolicitacao  DateTime @default(now()) @map("data_solicitacao")
  dataInicio       DateTime? @map("data_inicio")
  dataFim          DateTime? @map("data_fim")
  dataFlexivel     String?  @map("data_flexivel")
  classe           String?
  precoReferencia  Decimal  @default(0) @map("preco_referencia") @db.Decimal(10, 2)
  precoAtlas       Decimal  @default(0) @map("preco_atlas") @db.Decimal(10, 2)
  observacoes      String?
  checkinRealizado Boolean  @default(false) @map("checkin_realizado")
  createdAt        DateTime @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  responsavel Gestor? @relation(fields: [responsavelId], references: [id])

  @@map("produtos_clientes")
}

model Transacao {
  id             String    @id @default(cuid())
  gestorId       String    @map("gestor_id")
  clienteId      String?   @map("cliente_id")
  emissaoId      String?   @map("emissao_id")
  tipo           String
  descricao      String
  valor          Decimal   @db.Decimal(10, 2)
  dataVencimento DateTime? @map("data_vencimento")
  dataPagamento  DateTime? @map("data_pagamento")
  pago           Boolean   @default(false)
  recorrente     Boolean   @default(false)
  recorrenteAte  DateTime? @map("recorrente_ate")
  createdAt      DateTime  @default(now()) @map("created_at")

  gestor  Gestor   @relation(fields: [gestorId], references: [id], onDelete: Cascade)
  cliente Cliente? @relation(fields: [clienteId], references: [id])
  emissao Emissao? @relation(fields: [emissaoId], references: [id])

  @@map("transacoes")
}

model MetaMensal {
  id        String   @id @default(cuid())
  empresaId String?  @map("empresa_id")
  gestorId  String?  @map("gestor_id")
  mes       Int
  ano       Int
  valor     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  empresa Empresa? @relation(fields: [empresaId], references: [id])

  @@unique([gestorId, mes, ano])
  @@map("metas_mensais")
}

model Renovacao {
  id              String   @id @default(cuid())
  clienteId       String   @map("cliente_id")
  produto         String
  inicioContrato  DateTime @map("inicio_contrato")
  fimContrato     DateTime @map("fim_contrato")
  economiaPeriodo Decimal  @default(0) @map("economia_periodo") @db.Decimal(12, 2)
  status          String   @default("A_RENOVAR")
  createdAt       DateTime @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("renovacoes")
}

model ProdutoCatalogo {
  id        String   @id @default(cuid())
  gestorId  String   @map("gestor_id")
  nome      String
  preco     Decimal  @default(0) @db.Decimal(10, 2)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("produtos_catalogo")
}

model Notificacao {
  id        String   @id @default(cuid())
  gestorId  String?  @map("gestor_id")
  tipo      String
  titulo    String
  mensagem  String
  canal     String   @default("EMAIL_PUSH")
  lida      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  gestor Gestor? @relation(fields: [gestorId], references: [id])

  @@map("notificacoes")
}

model SolicitacaoOrcamento {
  id                    String   @id @default(cuid())
  empresaId             String?  @map("empresa_id")
  clienteId             String?  @map("cliente_id")
  consultorId           String?  @map("consultor_id")
  nome                  String
  telefone              String
  email                 String?
  destinoDesejado       String?  @map("destino_desejado")
  dataViagem            DateTime? @map("data_viagem")
  quantidadePassageiros Int      @default(1) @map("quantidade_passageiros")
  observacoes           String?
  origemLead            String   @default("SITE") @map("origem_lead")
  status                String   @default("NOVA")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  cotacoes CotacaoAgencia[]

  @@index([status])
  @@index([origemLead])
  @@index([createdAt])
  @@map("solicitacoes_orcamento")
}

model CotacaoAgencia {
  id                String   @id @default(cuid())
  solicitacaoId     String?  @map("solicitacao_id")
  clienteId         String?  @map("cliente_id")
  consultorId       String?  @map("consultor_id")
  origemLead        String   @default("SITE") @map("origem_lead")
  destino           String
  dataViagem        DateTime? @map("data_viagem")
  status            String   @default("AGUARDANDO")
  valorTotalVenda   Decimal  @default(0) @map("valor_total_venda") @db.Decimal(12, 2)
  custoTotal        Decimal  @default(0) @map("custo_total") @db.Decimal(12, 2)
  lucroTotal        Decimal  @default(0) @map("lucro_total") @db.Decimal(12, 2)
  margemPercentual  Decimal  @default(0) @map("margem_percentual") @db.Decimal(8, 2)
  fornecedorMilhas  String?  @map("fornecedor_milhas")
  programaMilhas    String?  @map("programa_milhas")
  quantidadeMilhas  Int?     @map("quantidade_milhas")
  custoMilheiro     Decimal? @map("custo_milheiro") @db.Decimal(10, 2)
  custoTotalMilhas  Decimal? @map("custo_total_milhas") @db.Decimal(12, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  solicitacao SolicitacaoOrcamento? @relation(fields: [solicitacaoId], references: [id], onDelete: SetNull)
  itens       CotacaoItem[]
  vendas      VendaAgencia[]
  viagens     ViagemAgencia[]

  @@index([status])
  @@index([origemLead])
  @@index([createdAt])
  @@map("cotacoes_agencia")
}

model CotacaoItem {
  id              String   @id @default(cuid())
  cotacaoId       String   @map("cotacao_id")
  tipoItem        String   @map("tipo_item")
  descricao       String
  fornecedor      String?
  valorVenda      Decimal  @default(0) @map("valor_venda") @db.Decimal(12, 2)
  custoFornecedor Decimal  @default(0) @map("custo_fornecedor") @db.Decimal(12, 2)
  lucro           Decimal  @default(0) @db.Decimal(12, 2)
  observacoes     String?
  createdAt       DateTime @default(now()) @map("created_at")

  cotacao CotacaoAgencia @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)

  @@index([tipoItem])
  @@map("cotacao_itens")
}

model VendaAgencia {
  id              String   @id @default(cuid())
  cotacaoId       String?  @map("cotacao_id")
  clienteId       String?  @map("cliente_id")
  consultorId     String?  @map("consultor_id")
  valorVenda      Decimal  @default(0) @map("valor_venda") @db.Decimal(12, 2)
  custoTotal      Decimal  @default(0) @map("custo_total") @db.Decimal(12, 2)
  lucroTotal      Decimal  @default(0) @map("lucro_total") @db.Decimal(12, 2)
  status          String   @default("PAGAMENTO")
  pagamentoStatus String   @default("A_RECEBER") @map("pagamento_status")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  cotacao CotacaoAgencia? @relation(fields: [cotacaoId], references: [id], onDelete: SetNull)
  viagens ViagemAgencia[]

  @@index([status])
  @@index([pagamentoStatus])
  @@index([createdAt])
  @@map("vendas_agencia")
}

model ViagemAgencia {
  id                   String   @id @default(cuid())
  vendaId              String?  @map("venda_id")
  cotacaoId            String?  @map("cotacao_id")
  clienteId            String?  @map("cliente_id")
  consultorResponsavel String?  @map("consultor_responsavel")
  destino              String
  dataIda              DateTime? @map("data_ida")
  dataVolta            DateTime? @map("data_volta")
  status               String   @default("PLANEJADA")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  venda       VendaAgencia? @relation(fields: [vendaId], references: [id], onDelete: SetNull)
  cotacao     CotacaoAgencia? @relation(fields: [cotacaoId], references: [id], onDelete: SetNull)
  voos        VooOperacional[]
  hospedagens HospedagemOperacional[]
  transfers   TransferOperacional[]
  seguros     SeguroOperacional[]
  documentos  DocumentoAgencia[]

  @@index([status])
  @@index([dataIda])
  @@map("viagens_agencia")
}

model VooOperacional {
  id               String   @id @default(cuid())
  viagemId         String   @map("viagem_id")
  companhia        String
  localizador      String?
  origem           String
  destino          String
  dataHoraPartida  DateTime? @map("data_hora_partida")
  dataHoraChegada  DateTime? @map("data_hora_chegada")
  statusCheckin    String   @default("NAO_DISPONIVEL") @map("status_checkin")
  createdAt        DateTime @default(now()) @map("created_at")

  viagem ViagemAgencia @relation(fields: [viagemId], references: [id], onDelete: Cascade)

  @@index([dataHoraPartida])
  @@index([statusCheckin])
  @@map("voos_operacionais")
}

model HospedagemOperacional {
  id        String   @id @default(cuid())
  viagemId  String   @map("viagem_id")
  hotel     String
  checkin   DateTime?
  checkout  DateTime?
  voucher   String?
  status    String   @default("PENDENTE")
  createdAt DateTime @default(now()) @map("created_at")

  viagem ViagemAgencia @relation(fields: [viagemId], references: [id], onDelete: Cascade)

  @@index([checkin])
  @@index([checkout])
  @@map("hospedagens_operacionais")
}

model TransferOperacional {
  id          String   @id @default(cuid())
  viagemId    String   @map("viagem_id")
  fornecedor  String?
  data        DateTime?
  horario     String?
  motorista   String?
  observacoes String?
  createdAt   DateTime @default(now()) @map("created_at")

  viagem ViagemAgencia @relation(fields: [viagemId], references: [id], onDelete: Cascade)

  @@index([data])
  @@map("transfers_operacionais")
}

model SeguroOperacional {
  id           String   @id @default(cuid())
  viagemId     String   @map("viagem_id")
  seguradora   String
  numeroApolice String? @map("numero_apolice")
  validade     DateTime?
  documentoPdf String?  @map("documento_pdf")
  createdAt    DateTime @default(now()) @map("created_at")

  viagem ViagemAgencia @relation(fields: [viagemId], references: [id], onDelete: Cascade)

  @@index([validade])
  @@map("seguros_operacionais")
}

model DocumentoAgencia {
  id              String   @id @default(cuid())
  viagemId        String?  @map("viagem_id")
  clienteId       String?  @map("cliente_id")
  tipo            String
  titulo          String
  status          String   @default("RASCUNHO")
  valor           Decimal? @db.Decimal(12, 2)
  linkArquivo     String?  @map("link_arquivo")
  linkAssinatura  String?  @map("link_assinatura")
  statusAssinatura String? @map("status_assinatura")
  dataAssinatura  DateTime? @map("data_assinatura")
  ipAssinatura    String?  @map("ip_assinatura")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  viagem ViagemAgencia? @relation(fields: [viagemId], references: [id], onDelete: SetNull)

  @@index([tipo])
  @@index([status])
  @@map("documentos_agencia")
}

model AutomacaoAgencia {
  id        String   @id @default(cuid())
  evento    String
  canal     String   @default("WHATSAPP_EMAIL")
  ativa     Boolean  @default(true)
  titulo    String
  mensagem  String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([evento])
  @@map("automacoes_agencia")
}

model EstoqueMilhasPrograma {
  id                 String   @id @default(cuid())
  programa           String   @unique
  logoUrl            String?  @map("logo_url")
  saldoAtual         Int      @default(0) @map("saldo_atual")
  custoTotal         Decimal  @default(0) @map("custo_total") @db.Decimal(12, 2)
  custoMedioMilheiro Decimal  @default(0) @map("custo_medio_milheiro") @db.Decimal(10, 2)
  clubeMensalMilhas  Int      @default(0) @map("clube_mensal_milhas")
  clubeCustoMensal   Decimal  @default(0) @map("clube_custo_mensal") @db.Decimal(10, 2)
  fornecedorNome     String?  @map("fornecedor_nome")
  fornecedorContato  String?  @map("fornecedor_contato")
  fornecedorEmail    String?  @map("fornecedor_email")
  observacoes        String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  movimentacoes MovimentacaoEstoqueMilhas[]

  @@map("estoque_milhas_programas")
}

model MovimentacaoEstoqueMilhas {
  id          String   @id @default(cuid())
  estoqueId   String   @map("estoque_id")
  tipo        String   @default("ENTRADA")
  quantidade  Int
  custoTotal  Decimal  @default(0) @map("custo_total") @db.Decimal(12, 2)
  descricao   String?
  createdAt   DateTime @default(now()) @map("created_at")

  estoque EstoqueMilhasPrograma @relation(fields: [estoqueId], references: [id], onDelete: Cascade)

  @@index([tipo])
  @@index([createdAt])
  @@map("movimentacoes_estoque_milhas")
}

model BackupSnapshot {
  id           String   @id @default(cuid())
  reason       String   @default("manual")
  status       String   @default("OK")
  payload      Json
  recordCounts Json?    @map("record_counts")
  sizeBytes    Int      @default(0) @map("size_bytes")
  createdById  String?  @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("backup_snapshots")
}
